FROM python:3.11-slim

ENV UV_LINK_MODE=copy \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

COPY pyproject.toml .python-version README.md ./
COPY src ./src

RUN pip install --no-cache-dir uv && \
    uv sync --no-dev

EXPOSE 8000

CMD ["uv", "run", "python", "-m", "anima_gs_ghost.serve"]

